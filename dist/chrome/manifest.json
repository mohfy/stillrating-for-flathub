{
  "manifest_version": 3,
  "name": "StillRating for Flathub",
  "version": "1.0.1",
  "description": "Shows StillRating badges on Flathub app pages using the StillHQ saDB repository.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://flathub.org/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://flathub.org/*"
      ],
      "js": [
        "vendor/js-yaml.min.js",
        "content.js"
      ],
      "css": [
        "badge.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
